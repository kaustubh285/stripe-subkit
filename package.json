{
	"name": "stripe-subkit",
	"version": "0.1.0",
	"description": "Bring order to your Stripe customers and subscriptions: metadata-aware lookups, normalized reads, and user-centric helpers for TypeScript backends.",
	"keywords": [
		"stripe",
		"subscriptions",
		"typescript",
		"payments",
		"billing"
	],
	"author": "Kaustubh Deshpande<kdevdeshpande@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kaustubh285/stripe-subkit.git"
	},
	"homepage": "https://github.com/kaustubh285/stripe-subkit#readme",
	"bugs": {
		"url": "https://github.com/kaustubh285/stripe-subkit/issues"
	},
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist",
		"prepublishOnly": "bun run clean && bun run build && bun run check-deps",
		"dev": "tsc -w",
		"test": "bun test tests/test.test.ts",
		"typecheck": "tsc --noEmit",
		"check-deps": "echo 'Dependency check complete - using bun for package management'",
		"check-package": "bun run typecheck && bun run build && bun run test"
	},
	"peerDependencies": {
		"stripe": ">=10.0.0"
	},
	"devDependencies": {
		"@jest/globals": "^30.3.0",
		"@types/bun": "latest",
		"@types/node": "^20.0.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {},
	"peerDependenciesMeta": {
		"stripe": {
			"optional": false
		}
	}
}
